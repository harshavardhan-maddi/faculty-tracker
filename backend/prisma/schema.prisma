datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum Role {
  HOD
  SUB_ADMIN
  CR
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  userId           String    @unique @map("user_id")
  password         String
  role             Role
  className        String?   @map("class_name")
  createdAt        DateTime  @default(now()) @map("created_at")
  faceDescriptor   String?   @map("face_descriptor")
  faceAuthEnabled  Boolean   @default(false) @map("face_auth_enabled")
  faceRegisteredAt DateTime? @map("face_registered_at")
  faceUpdatedAt    DateTime? @map("face_updated_at")
  faceUpdateCount  Int       @default(0) @map("face_update_count")
  faceUpdateMonth  String?   @map("face_update_month")

  @@map("users")
}

model Classroom {
  id         Int          @id @default(autoincrement())
  roomNumber String       @map("room_number")
  className  String       @map("class_name")
  createdAt  DateTime     @default(now()) @map("created_at")
  timetables Timetable[]
  logs       FacultyLog[]

  @@unique([roomNumber, className])
  @@map("classrooms")
}

model Faculty {
  id          Int     @id @default(autoincrement())
  facultyName String  @unique @map("faculty_name")
  phoneNumber String? @map("phone_number")

  @@map("faculty")
}

model Timetable {
  id          Int       @id @default(autoincrement())
  classroomId Int       @map("classroom_id")
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  day         String    // e.g., "Monday", "Tuesday", etc.
  periodNo    Int       @map("period_no")
  startTime   String    @map("start_time") // Format: "HH:MM" (e.g. "09:00")
  endTime     String    @map("end_time")   // Format: "HH:MM" (e.g. "10:00")
  facultyName String    @map("faculty_name")
  subjectName String    @map("subject_name")

  @@map("timetables")
}

model FacultyLog {
  id          Int       @id @default(autoincrement())
  classroomId Int       @map("classroom_id")
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  facultyName String    @map("faculty_name")
  periodNo    Int       @map("period_no")
  entryTime   DateTime? @map("entry_time") // Null if "Not Entered"
  status      String    // "Present" or "Not Entered"
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("faculty_logs")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model FaceAuditLog {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  action    String   // "REGISTRATION", "UPDATE", "REMOVAL", "LOGIN_SUCCESS", "LOGIN_FAILURE"
  details   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("face_audit_logs")
}
