datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  engineType    = "binary"
}

enum Role {
  HOD
  SUB_ADMIN
  CR
}

model User {
  id                 Int       @id @default(autoincrement())
  name               String
  userId             String    @unique @map("user_id")
  password           String
  role               Role
  className          String?   @map("class_name")
  createdAt          DateTime  @default(now()) @map("created_at")
  fingerprintEnabled Boolean   @default(false) @map("fingerprint_enabled")

  @@map("users")
}

model Classroom {
  id         Int          @id @default(autoincrement())
  roomNumber String       @map("room_number")
  className  String       @map("class_name")
  createdAt  DateTime     @default(now()) @map("created_at")
  timetables Timetable[]
  logs       FacultyLog[]

  @@unique([roomNumber, className])
  @@map("classrooms")
}

model Faculty {
  id          Int     @id @default(autoincrement())
  facultyName String  @unique @map("faculty_name")
  phoneNumber String? @map("phone_number")

  @@map("faculty")
}

model Timetable {
  id          Int       @id @default(autoincrement())
  classroomId Int       @map("classroom_id")
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  day         String    // e.g., "Monday", "Tuesday", etc.
  periodNo    Int       @map("period_no")
  startTime   String    @map("start_time") // Format: "HH:MM" (e.g. "09:00")
  endTime     String    @map("end_time")   // Format: "HH:MM" (e.g. "10:00")
  facultyName String    @map("faculty_name")
  subjectName String    @map("subject_name")

  @@map("timetables")
}

model FacultyLog {
  id          Int       @id @default(autoincrement())
  classroomId Int       @map("classroom_id")
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  facultyName String    @map("faculty_name")
  periodNo    Int       @map("period_no")
  entryTime   DateTime? @map("entry_time") // Null if "Not Entered"
  status      String    // "Present" or "Not Entered"
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("faculty_logs")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Fingerprint {
  id           Int      @id @default(autoincrement())
  userId       String   @unique @map("user_id")
  credentialId String   @map("credential_id")
  publicKey    String   @map("public_key")
  counter      Int      @default(0)
  transports   String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("fingerprints")
}

model FingerprintAuditLog {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  action    String   // "REGISTRATION", "REMOVAL", "LOGIN_SUCCESS", "LOGIN_FAILURE", "TOGGLE_ON", "TOGGLE_OFF"
  details   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("fingerprint_audit_logs")
}
